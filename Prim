#include <stdio.h>

#define MAX 10
#define INF 9999

int main()
{
    int n, i, j;
    int graph[MAX][MAX];
    int visited[MAX] = {0};
    int edges = 0;
    int min, a, b;
    int minCost = 0;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    printf("Enter adjacency matrix:\n");
    for(i = 0; i < n; i++)
    {
        for(j = 0; j < n; j++)
        {
            scanf("%d", &graph[i][j]);

            if(graph[i][j] == 0)
                graph[i][j] = INF;
        }
    }

    visited[0] = 1;

    printf("\nEdges in Minimum Spanning Tree:\n");

    while(edges < n - 1)
    {
        min = INF;

        for(i = 0; i < n; i++)
        {
            if(visited[i])
            {
                for(j = 0; j < n; j++)
                {
                    if(!visited[j] && graph[i][j] < min)
                    {
                        min = graph[i][j];
                        a = i;
                        b = j;
                    }
                }
            }
        }

        printf("%d --> %d : Cost = %d\n", a, b, min);

        minCost += min;
        visited[b] = 1;
        edges++;
    }

    printf("\nMinimum Cost = %d\n", minCost);

    return 0;
}
