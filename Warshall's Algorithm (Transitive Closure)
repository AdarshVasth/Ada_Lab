#include <iostream>
using namespace std;

void Warshall(int A[][100], int P[][100], int n)
{
    // Copy adjacency matrix to path matrix
    for (int i = 0; i < n; i++)
    {
        for (int j = 0; j < n; j++)
        {
            P[i][j] = A[i][j];
        }
    }

    // Warshall's Algorithm
    for (int k = 0; k < n; k++)
    {
        for (int i = 0; i < n; i++)
        {
            for (int j = 0; j < n; j++)
            {
                if (P[i][j] == 0 &&
                    P[i][k] == 1 &&
                    P[k][j] == 1)
                {
                    P[i][j] = 1;
                }
            }
        }
    }
}

int main()
{
    int n;
    cout << "Enter number of vertices: ";
    cin >> n;

    int A[100][100], P[100][100];

    cout << "Enter adjacency matrix:\n";
    for (int i = 0; i < n; i++)
    {
        for (int j = 0; j < n; j++)
        {
            cin >> A[i][j];
        }
    }

    Warshall(A, P, n);

    cout << "\nTransitive Closure Matrix:\n";
    for (int i = 0; i < n; i++)
    {
        for (int j = 0; j < n; j++)
        {
            cout << P[i][j] << " ";
        }
        cout << endl;
    }

    return 0;
}
