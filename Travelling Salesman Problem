#include <stdio.h>

#define MAX 10
#define INF 999999

int n;
int cost[MAX][MAX];
int memo[1 << MAX][MAX];

int tsp(int mask, int pos)
{
    if (mask == (1 << n) - 1)
        return cost[pos][0];

    if (memo[mask][pos] != -1)
        return memo[mask][pos];

    int ans = INF;

    for (int city = 0; city < n; city++)
    {
        if ((mask & (1 << city)) == 0)
        {
            int newAns = cost[pos][city] +
                         tsp(mask | (1 << city), city);

            if (newAns < ans)
                ans = newAns;
        }
    }

    return memo[mask][pos] = ans;
}

int main()
{
    printf("Enter number of cities: ");
    scanf("%d", &n);

    printf("Enter cost matrix:\n");
    for (int i = 0; i < n; i++)
    {
        for (int j = 0; j < n; j++)
        {
            scanf("%d", &cost[i][j]);
        }
    }

    for (int i = 0; i < (1 << n); i++)
    {
        for (int j = 0; j < n; j++)
        {
            memo[i][j] = -1;
        }
    }

    int minimumCost = tsp(1, 0);

    printf("Minimum travelling cost = %d\n", minimumCost);

    return 0;
}
